<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingHorizontal="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="8dp">

    <!-- ========== 顶部菜单栏 ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/menuButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="≡"
            android:textSize="28sp"
            android:textColor="#546E7A"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- ========== 录制卡片 ========== -->
    <LinearLayout
        android:id="@+id/recordArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/card_bg"
        android:elevation="2dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="手势选择"
            android:textSize="14sp"
            android:textColor="#546E7A"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/gestureSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/counterText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已采集: 0 次"
            android:textSize="13sp"
            android:textColor="#90A4AE"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="起始编号: "
                android:textSize="13sp"
                android:textColor="#607D8B" />

            <EditText
                android:id="@+id/startNumberInput"
                android:layout_width="70dp"
                android:layout_height="36dp"
                android:inputType="number"
                android:text="1"
                android:textSize="14sp"
                android:gravity="center"
                android:background="@drawable/btn_gray"
                android:textColor="#37474F" />
        </LinearLayout>

        <Button
            android:id="@+id/collectButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="开始采集"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_blue" />
    </LinearLayout>

    <!-- ========== 识别卡片 ========== -->
    <LinearLayout
        android:id="@+id/recogArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/card_bg"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <Button
            android:id="@+id/recogButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="开始识别"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_blue"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/recogResultText"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text=""
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@drawable/result_card" />

        <TextView
            android:id="@+id/recogInfoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/gestureImageView"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

        <ImageView
            android:id="@+id/spectrogramView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="fitCenter"
            android:background="#1A1A2E"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/envelopeView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="fitCenter"
            android:background="#1A1A2E"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ========== 底部按钮区 ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/recordModeBtn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="录制模式"
            android:textSize="16sp"
            android:textColor="#546E7A"
            android:background="@drawable/btn_gray"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/recogModeBtn"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="识别模式"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_blue"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- ========== 引擎按钮 ========== -->
    <Button
        android:id="@+id/engineButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="启动扬声器"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:background="@drawable/btn_orange" />

</LinearLayout>
